{
  "expo": {
    "name": "Unichat",
    "slug": "unichat",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "unichat",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#300033"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.unichat.app",
      "infoPlist": {
        "UIBackgroundModes": ["audio", "remote-notification"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#300033"
      },
      "package": "com.unichat.app",
      "permissions": ["WAKE_LOCK", "VIBRATE"]
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Unichat to access your photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
